# Base de datos (SQLite local por defecto). Para producción podés usar Postgres/Turso.
DATABASE_URL="file:./dev.db"

# Secreto para firmar la cookie de sesión. Cambialo por algo largo y aleatorio.
AUTH_SECRET="cambia-esto-por-un-string-largo-y-random-minimo-32-chars"

# Contraseña inicial de Cande (se pisa en el primer login si el hash está en DB).
# Si querés cambiarla, corré: npm run db:seed con INITIAL_PASSWORD distinto.
INITIAL_PASSWORD="candelita2026"
